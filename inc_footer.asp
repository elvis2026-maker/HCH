<script>
(function(){
  var fab = document.getElementById('chatFabMain');
  var panel = document.getElementById('chatPanel');
  var close = document.getElementById('chatClose');
  if(fab){ fab.addEventListener('click', function(){ panel.classList.toggle('open'); }); }
  if(close){ close.addEventListener('click', function(){ panel.classList.remove('open'); }); }
  // AJAX form submit
  var chatForm = document.getElementById('chatMsgForm');
  var chatMsg = document.getElementById('chatFormMsg');
  if(chatForm){
    chatForm.addEventListener('submit', function(e){
      e.preventDefault();
      var fd = new FormData(chatForm);
      var xhr = new XMLHttpRequest();
      xhr.open('POST', 'message_save.asp', true);
      xhr.onload = function(){
        chatMsg.style.display = 'block';
        if(xhr.status === 200 && xhr.responseText.indexOf('OK') !== -1){
          chatMsg.innerHTML = '<div class="form-msg success">✓ 留言已送出，我們將盡快回覆您！</div>';
          chatForm.reset();
        } else {
          chatMsg.innerHTML = '<div class="form-msg error">送出失敗，請直接寄信至 hch@hchtwn.com.tw</div>';
        }
      };
      xhr.onerror = function(){
        chatMsg.innerHTML = '<div class="form-msg error">網路錯誤，請直接寄信至 hch@hchtwn.com.tw</div>';
        chatMsg.style.display = 'block';
      };
      var params = '';
      fd.forEach(function(v,k){ params += encodeURIComponent(k)+'='+encodeURIComponent(v)+'&'; });
      xhr.setRequestHeader('Content-type','application/x-www-form-urlencoded');
      xhr.send(params);
    });
  }
})();
</script>
