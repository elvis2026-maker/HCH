      <input type="text" name="chat_partno" placeholder="詢問料號 Part No. (optional)">
      <textarea name="chat_msg" placeholder="訊息內容 Message *" required></textarea>
      <button type="submit">送出留言 <i class="fas fa-paper-plane"></i></button>
